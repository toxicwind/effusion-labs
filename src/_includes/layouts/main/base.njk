{% from "components/header.njk" import header %}
{% from "components/footer.njk" import footer %}
{% from "components/meta-aside.njk" import metaAside %}

{% set pageTitle = title or 'Untitled' %}
{% set pageDescription = metaDescription or description or '' %}
{% set siteUrl = (metadata and metadata.site and metadata.site.url) or '' %}
{% set canon = canonicalUrl or page.canonicalUrl or page.url %}
{% set canonicalHref = canon %}
{% if canonicalHref and siteUrl and '://' not in canonicalHref %}
  {% set canonicalHref = canonicalHref | absoluteUrl(siteUrl) %}
{% endif %}
{% if not canonicalHref and siteUrl and page and page.url %}
  {% set canonicalHref = page.url | absoluteUrl(siteUrl) %}
{% endif %}

{% set fullBleed = (fullBleed == true or fullBleed == 'true') %}
{% set metaOff = (metaDisable == true or metaDisable == 'true') %}
{% set showMainChrome = (chrome != false and chrome != 'false') %}
{% set showHud = showMainChrome and (showHud != false and showHud != 'false') %}
{% set showCursor = showMainChrome and (showCursor != false and showCursor != 'false') %}
{% set showHeroScene = showMainChrome and (showHeroScene != false and showHeroScene != 'false') %}
{% set metaEligible = (status or certainty or importance or tags or memory_ref or date or page.date) %}
{% set hasMeta = not fullBleed and metaEligible and not metaOff %}

<!DOCTYPE html>
<html lang="en" class="scroll-pt-16" data-theme="hypebrut">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="color-scheme" content="dark light">
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f7f5f3">
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#16161a">
    <meta name="msapplication-TileColor" content="#16161a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <title>{{ pageTitle }} | Effusion Labs</title>
    {% if pageDescription %}<meta name="description" content="{{ pageDescription }}">{% endif %}

    {% if canonicalHref %}
      <link rel="canonical" href="{{ canonicalHref }}" vite-ignore>
      <meta property="og:url" content="{{ canonicalHref }}" vite-ignore>
    {% endif %}
    <meta property="og:title" content="{{ ogTitle or pageTitle }}">
    {% if pageDescription %}<meta property="og:description" content="{{ ogDescription or pageDescription }}">{% endif %}
    <meta property="og:site_name" content="Effusion Labs">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or pageTitle }}">
    {% if pageDescription %}<meta name="twitter:description" content="{{ ogDescription or pageDescription }}">{% endif %}

    {{ headExtra | safe }}
    {% block head %}{% endblock %}

    <script>
      try {
        const saved = localStorage.getItem('theme')
        const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
        document.documentElement.setAttribute('data-theme', saved || (prefersDark ? 'hypebrut' : 'silk'))
      } catch (e) {}
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Manrope:wght@300..800&family=Plus+Jakarta+Sans:wght@400..800&display=swap"
      rel="stylesheet"
    >

    <link rel="stylesheet" href="{{ '/assets/css/app.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/liquid-glass.css' | url }}">
    <script type="module" src="{{ '/assets/js/app.js' | url }}"></script>

    <link rel="icon" type="image/svg+xml" href="{{ '/favicon.svg' | url }}">
    <link rel="icon" href="{{ '/favicon.ico' | url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/apple-touch-icon.png' | url }}">
    <meta name="apple-mobile-web-app-title" content="Effusion Labs">
    <link rel="manifest" href="{{ '/site.webmanifest' | url }}">
  </head>
  <body class="bg-base-100 text-base-content font-body antialiased">
    {% if showHud %}
      <div id="hud-layer" aria-hidden="true">
        <div class="hud-scanner"></div>
        <div class="hud-status">SYS.OP: NORMAL<br>LOC: EFFUSION_LABS</div>
      </div>
    {% endif %}

    {% if showMainChrome %}
      <a href="#main" class="skiplink">Skip to content</a>
      {{ header(nav, page, branding) }}
    {% endif %}

    {% set mainClass = 'min-h-[60vh]' %}
    {% if fullBleed %}
      {% set mainClass = mainClass + ' w-full px-0' %}
    {% else %}
      {% set mainClass = mainClass + ' max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-10' %}
    {% endif %}

    <main id="main" class="{{ mainClass }}" tabindex="-1">
      {% if fullBleed %}
        {{ content | safe }}
      {% else %}
        <div class="{% if hasMeta %}xl:grid xl:grid-cols-[1fr_18rem] xl:gap-10{% else %}stack{% endif %}" style="--space: var(--space-l)">
          <article class="prose max-w-none m-0 {% if hasMeta %}xl:col-span-1{% endif %}">
            {% if showTitle != false %}
              <header class="mb-6 lg:mb-8">
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight leading-tight">{{ pageTitle }}</h1>
                {% if description %}<p class="text-lg opacity-70 mt-3">{{ description }}</p>{% endif %}
              </header>
            {% endif %}
            {{ content | safe }}
          </article>

          {% if hasMeta %}
            {% set d = date or page.date %}
            <aside class="mt-8 xl:mt-0">{{ metaAside(status, d, certainty, importance, tags, memory_ref) }}</aside>
          {% endif %}
        </div>
      {% endif %}
    </main>

    {% if showMainChrome %}
      {{ footer(buildTime) }}
    {% endif %}

    {% if showHeroScene %}
      <div id="hero-background" class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true"></div>
      <div id="react-overlay" class="fixed inset-0 z-10 pointer-events-none" aria-hidden="true"></div>
      <script type="module" src="{{ '/assets/js/hero-scene.js' | url }}"></script>
    {% endif %}

    {% if showHud %}
      <script type="module" src="{{ '/assets/js/hud.js' | url }}"></script>
    {% endif %}

    {% if showCursor %}
      <script type="module">
        import { initCursor } from '{{ '/assets/js/cursor.js' | url }}'
        const motionReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches
        if (!motionReduced && window.matchMedia('(min-width: 768px)').matches) {
          initCursor()
        }
      </script>
    {% endif %}
  </body>
</html>
